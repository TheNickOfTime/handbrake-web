{
  "extends": "./tsconfig.json",
  "references": [{ "path": "../shared" }],
  "include": ["src", "vite.config.ts"],
  "compilerOptions": {
    "composite": true,

    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,

    "baseUrl": ".",
    "paths": {
      "logging": ["./src/scripts/logging"],
      "~routes/*": ["./src/routes/*"],
      "~scripts/*": ["./src/scripts/*"],
      "~socket/*": ["./src/socket/*"],
      "~shared/*": ["../shared/*"]
    },

    "outDir": "./build/server"
  }
}
