{
  "extends": "./tsconfig.json",
  "references": [{ "path": "../shared" }],
  "include": ["src", "vite.config.ts"],
  "compilerOptions": {
    "composite": true,

    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,

    "baseUrl": ".",
    "paths": {
      "routes/*": ["./src/routes/*"],
      "logging": ["./src/scripts/logging"],
      "scripts/*": ["./src/scripts/*"],
      "socket/*": ["./src/socket/*"],
      "shared/*": ["../shared/*"],
      "types/*": ["../shared/types/*"],
      "funcs/*": ["../shared/funcs/*"]
    },

    "outDir": "./build/server"
  }
}
